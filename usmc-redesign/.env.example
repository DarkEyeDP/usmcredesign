# Copy this file to .env.local and fill in the values.
# All VITE_* vars are public — never put secrets here.
# See CLAUDE.md "Cloudflare Workers & External Services" for the full setup guide.

# News metrics Worker (used by `npm run metrics:dev`)
# Local dev:   http://127.0.0.1:8787  (run `npx wrangler dev` in workers/news-metrics/)
# Production:  https://news-metrics.darkeyegraphics.workers.dev
VITE_NEWS_METRICS_URL=https://news-metrics.darkeyegraphics.workers.dev

# School search Worker (College & University page + Degree Planner school selector)
# Required for /education/college-university and /education/degree-planner to fetch data.
# If absent, school search silently no-ops with no error thrown.
VITE_SCHOOL_SEARCH_WORKER_URL=https://school-search.darkeyegraphics.workers.dev

# Jina Reader API key (used by `npm run fetch-news` to fetch article bodies)
# Get a free key at https://jina.ai — 10M tokens free.
# Without this, article fetches will be blocked (401) on AT&T/residential IPs.
JINA_API_KEY=jina_...
